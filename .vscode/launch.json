{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Current File (LLDB)",
            "type": "codelldb",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "preLaunchTask": "Nix G++ build",
            "console": "integratedTerminal",
            "initCommands": [
                "settings set target.process.thread.step-avoid-regexp ^std::"
            ]
        },
        {
            "name": "Debug a.out (LLDB)",
            "type": "codelldb",
            "request": "launch",
            "program": "${workspaceFolder}/a.out",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "console": "integratedTerminal"
        }
    ]
}