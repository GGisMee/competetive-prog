{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Nix G++ build",
            "command": "g++",
            "args": [
                "-std=c++20",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Kompilerar med g++ inuti Nix-skal"
        }
    ]
}